@article{keidingMethodExpectedNumber1987,
  title = {The {{Method}} of {{Expected Number}} of {{Deaths}}, 1786-1886-1986, {{Correspondent Paper}}},
  author = {Keiding, Niels},
  year = 1987,
  journal = {International Statistical Review / Revue Internationale de Statistique},
  volume = {55},
  number = {1},
